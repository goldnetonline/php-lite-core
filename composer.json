{
    "name": "goldnetonline/php-lite-core",
    "description": "Lean core runtime for php-lite websites.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4 <9.0",
        "filp/whoops": "^2.17",
        "mailgun/mailgun-php": "^4.3",
        "symfony/mailer": "^7.3",
        "symfony/mime": "^7.3",
        "twig/twig": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Goldnetonline\\PhpLiteCore\\": "src/Core/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    }
}
